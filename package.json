{
  "name": "agent",
  "version": "1.0.0",
  "description": "Boreal AI Agent Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "console": "ts-node-dev --respawn --transpile-only src/console/chatConsole.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "worker": "ts-node-dev --respawn --transpile-only src/infrastructure/mayaWorker.ts",
    "predeploy": "ts-node src/testing/preDeployCheck.ts",
    "lint": "tsc --noEmit",
    "lint:api-guards": "bash scripts/ci-api-guards.sh",
    "test:ci": "jest --runInBand --detectOpenHandles --forceExit",
    "verify:no-http": "node scripts/verify-no-http.js",
    "verify:no-async-leaks": "rg -n \"setTimeout\\(|setInterval\\(|void .*\\(\" src && exit 1 || exit 0",
    "verify:no-global-state": "rg -n \"let .* = \\{\\}|global\\.\" src && exit 1 || exit 0",
    "verify:no-floating-promises": "rg -n \"Promise\\.(then|catch)\\(\" src && exit 1 || exit 0"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.4",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@types/morgan": "^1.9.10",
    "axios": "^1.14.0",
    "body-parser": "^2.2.2",
    "bullmq": "^5.70.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "luxon": "^3.7.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openai": "^4.104.0",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "readline-sync": "^1.4.10",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.8.1",
    "twilio": "^4.23.0",
    "uuid": "^13.0.0",
    "validator": "^13.12.0",
    "ws": "^8.20.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.37",
    "@types/pdfkit": "^0.17.5",
    "@types/readline-sync": "^1.4.8",
    "@types/validator": "^13.15.10",
    "jest": "^29.6.4",
    "jest-environment-jsdom": "^29.6.4",
    "jest-util": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.10.0 <21.0.0"
  }
}
